# =========================================================
# Boardroom AI · environment
# Copy to .env.local for dev. Production values go in
# Cloudflare Pages → Settings → Environment Variables, and
# secrets via `pnpm wrangler secret put NAME`.
# =========================================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY
# SECRET — never commit. Server-only.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Anthropic — SECRET, server-only.
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Stripe — SECRET, server-only.
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_GROWTH=price_xxx
STRIPE_PRICE_SCALE=price_xxx
STRIPE_PRICE_SETUP=price_xxx
STRIPE_PRICE_TOPUP=price_xxx

# CEO Business Dashboard module — SECRET, server-only.
# Signs report-export URLs (1-hour expiry). Generate: openssl rand -hex 32
EXPORT_SIGNING_SECRET=CHANGE_ME
# HMAC secret for the venture data feed (POST /api/ceo/feed) — external venture
# systems (AHMAD AI CEO, EzPOS) push daily numbers signed with this.
# Generate: openssl rand -hex 32. Same value goes in the pushing system's env.
CEO_FEED_SECRET=CHANGE_ME
# Bearer secret for the group-brief READ seam (GET /api/ceo/group-brief) —
# the standalone CF ai app pulls the whole-group brief with this.
# Generate: openssl rand -hex 32. Same value goes in the CF ai app's env.
CEO_BRIEF_SECRET=CHANGE_ME

# LLM Gateway (AiOS Cost Router) — powers /ceo/llm-spend.
# The gateway is the single choke point every venture app calls instead of an
# LLM provider directly; the CEO dashboard reads its /stats aggregates.
# Issue the key with `node scripts/hash-key.mjs aiforceo` in the llm-gateway
# repo, then register the printed hash in its app_keys table. Server-only.
LLM_GATEWAY_URL=https://llm-gateway.example.workers.dev
LLM_GATEWAY_KEY=CHANGE_ME
